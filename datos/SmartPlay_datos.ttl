sp:recomiendaJuego a owl:ObjectProperty ;
    rdfs:domain sp:Recomendacion ;
    rdfs:range sp:Videojuego .

sp:region a owl:DatatypeProperty ;
    rdfs:domain sp:Usuario ;
    rdfs:range xsd:string .

sp:similarA a owl:ObjectProperty ;
    rdfs:domain sp:Videojuego ;
