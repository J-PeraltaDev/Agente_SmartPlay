    rdfs:domain sp:Videojuego ;
    rdfs:range xsd:decimal .

sp:puntuacionRelevancia a owl:DatatypeProperty ;
    rdfs:domain sp:Recomendacion ;
    rdfs:range xsd:decimal .

sp:recibeRecomendacion a owl:ObjectProperty ;
    rdfs:domain sp:Usuario ;
    rdfs:range sp:Recomendacion ;
